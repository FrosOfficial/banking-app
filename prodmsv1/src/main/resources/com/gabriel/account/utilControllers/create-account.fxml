<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefWidth="520.0"
            prefHeight="700.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gabriel.account.utilControllers.CreateAccountController">

   <!-- ================= HEADER ================= -->

   <top>

      <VBox alignment="CENTER"
            spacing="8">

         <padding>
            <Insets top="25"
                    right="25"
                    bottom="20"
                    left="25"/>
         </padding>

         <Label text="Create New Account"
                styleClass="header-title"/>

         <Label text="Enter the customer's information below"
                style="-fx-font-size:13px;
                          -fx-text-fill:#6E6E73;"/>

      </VBox>

   </top>

   <!-- ================= BODY ================= -->

   <center>

      <VBox spacing="22">

         <padding>
            <Insets top="10"
                    right="25"
                    bottom="25"
                    left="25"/>
         </padding>

         <!-- Card -->

         <VBox spacing="20"
               styleClass="card">

            <Label text="Customer Information"
                   styleClass="form-label"/>

            <GridPane hgap="18"
                      vgap="18">

               <columnConstraints>

                  <ColumnConstraints
                          prefWidth="130"/>

                  <ColumnConstraints
                          hgrow="ALWAYS"/>

               </columnConstraints>

               <!-- Name -->

               <Label text="Full Name"
                      styleClass="form-label"
                      GridPane.rowIndex="0"/>

               <TextField fx:id="tfName"
                          promptText="John Doe"
                          prefHeight="42"
                          GridPane.columnIndex="1"
                          GridPane.rowIndex="0"/>

               <!-- Description -->

               <Label text="Description"
                      styleClass="form-label"
                      GridPane.rowIndex="1"/>

               <TextField fx:id="tfDesc"
                          promptText="Savings Account"
                          prefHeight="42"
                          GridPane.columnIndex="1"
                          GridPane.rowIndex="1"/>

               <!-- Type -->

               <Label text="Account Type"
                      styleClass="form-label"
                      GridPane.rowIndex="2"/>

               <ComboBox fx:id="cbUom"
                         prefHeight="42"
                         GridPane.columnIndex="1"
                         GridPane.rowIndex="2"/>

               <!-- Balance -->

               <Label text="Initial Balance"
                      styleClass="form-label"
                      GridPane.rowIndex="3"/>

               <TextField fx:id="tfBalance"
                          text="0.0"
                          prefHeight="42"
                          GridPane.columnIndex="1"
                          GridPane.rowIndex="3"/>

               <!-- Email -->

               <Label text="Email Address"
                      styleClass="form-label"
                      GridPane.rowIndex="4"/>

               <TextField fx:id="tfEmail"
                          promptText="name@example.com"
                          prefHeight="42"
                          GridPane.columnIndex="1"
                          GridPane.rowIndex="4"/>

               <!-- Password -->

               <Label text="Password"
                      styleClass="form-label"
                      GridPane.rowIndex="5"/>

               <PasswordField fx:id="tfPassword"
                              prefHeight="42"
                              GridPane.columnIndex="1"
                              GridPane.rowIndex="5"/>

            </GridPane>

         </VBox>

         <!-- Buttons -->

         <HBox alignment="CENTER"
               spacing="20">

            <Button fx:id="btnSubmit"
                    text="Create Account"
                    prefWidth="180"
                    prefHeight="45"
                    styleClass="btn-primary"
                    mnemonicParsing="false"
                    onAction="#onSubmit"/>

            <Button fx:id="btnNext"
                    text="Back"
                    prefWidth="140"
                    prefHeight="45"
                    styleClass="btn-close"
                    mnemonicParsing="false"
                    onAction="#onBack"/>

         </HBox>

      </VBox>

   </center>

</BorderPane>