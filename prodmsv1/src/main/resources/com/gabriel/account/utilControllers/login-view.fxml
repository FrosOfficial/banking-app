<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="540.0"
            prefWidth="960.0"
            xmlns="http://javafx.com/javafx/17.0.2-ea"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gabriel.account.utilControllers.LoginController">

    <VBox alignment="CENTER"
          spacing="30.0"
          AnchorPane.topAnchor="0.0"
          AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0">

        <padding>
            <Insets top="45" right="40" bottom="45" left="40"/>
        </padding>

        <VBox alignment="CENTER"
              spacing="24"
              maxWidth="420"
              styleClass="card"
              style="-fx-padding:32; -fx-spacing:22;">

            <VBox alignment="CENTER" spacing="10">
                <ImageView fx:id="loginImage"
                           fitHeight="120"
                           fitWidth="120"
                           preserveRatio="true"
                           pickOnBounds="true"/>

                <Label text="Secure Login"
                       styleClass="header-title"
                       style="-fx-font-size: 28px; -fx-font-weight: bold;"/>

                <Label text="Sign in to continue"
                       style="-fx-font-size: 13px; -fx-text-fill:#6b7280;"/>
            </VBox>

            <VBox spacing="20" maxWidth="320">

                <VBox spacing="7">
                    <Label text="Email Address"
                           styleClass="form-label"/>

                    <TextField fx:id="tfEmail"
                               promptText="name@example.com"
                               prefHeight="44"/>
                </VBox>

                <VBox spacing="7">

                    <Label text="Password"
                           styleClass="form-label"/>

                    <StackPane>

                        <PasswordField fx:id="tfPassword"
                                       promptText="Enter password"
                                       prefHeight="44"/>

                        <TextField fx:id="tfPasswordPlain"
                                   promptText="Enter password"
                                   prefHeight="44"
                                   visible="false"
                                   managed="false"/>

                    </StackPane>

                    <CheckBox fx:id="chkShowPassword"
                              text="Show Password"
                              onAction="#onToggleShowPassword"
                              style="-fx-font-size:12px; -fx-text-fill:#6b7280;"/>
                </VBox>

            </VBox>

            <VBox spacing="12"
                  alignment="CENTER"
                  maxWidth="320">

                <Button fx:id="btnLogin"
                        text="Login"
                        prefWidth="320"
                        prefHeight="46"
                        styleClass="btn-primary"
                        onAction="#onLogin"/>

                <Button fx:id="btnCancel"
                        text="Cancel"
                        prefWidth="320"
                        prefHeight="42"
                        styleClass="btn-close"
                        onAction="#onCancel"/>

            </VBox>
        </VBox>

    </VBox>

</AnchorPane>