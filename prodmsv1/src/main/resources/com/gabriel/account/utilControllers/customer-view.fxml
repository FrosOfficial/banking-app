<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="customerPane" prefHeight="650.0" prefWidth="350.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gabriel.account.utilControllers.CustomerController">
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>
    
    <top>
        <VBox alignment="CENTER" spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="15.0" />
            </padding>
            <Label styleClass="header-title" text="Customer Transactions" />
            <Button text="Log Out" styleClass="btn-close" onAction="#onLogOut" alignment="CENTER" />
        </VBox>
    </top>
    
    <center>
        <VBox spacing="20.0" BorderPane.alignment="CENTER">
            <!-- Account Loading -->
            <VBox spacing="8.0" style="-fx-background-color: white; -fx-padding: 10px; -fx-background-radius: 6px; -fx-border-color: #e5e7eb; -fx-border-radius: 6px;">
                <Label text="Enter Account ID:" styleClass="form-label" />
                <HBox spacing="10.0">
                    <TextField fx:id="tfSearchId" promptText="e.g. 1" HBox.hgrow="ALWAYS" />
                    <Button text="Load" styleClass="btn-primary" onAction="#onLoadAccount" />
                </HBox>
                <Label fx:id="lblStatus" text="Enter Account ID and click Load." style="-fx-text-fill: #4b5563; -fx-font-size: 11px;" />
            </VBox>
            
            <!-- Account Details / Balance Inquiry display -->
            <VBox spacing="10.0" style="-fx-background-color: #f3f4f6; -fx-padding: 15px; -fx-background-radius: 6px; -fx-border-color: #d1d5db; -fx-border-radius: 6px;">
                <Label text="Account Details" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                <Label fx:id="lblOwner" text="Owner: -" styleClass="form-label" />
                <Label fx:id="lblType" text="Account Type: -" styleClass="form-label" />
                <Label fx:id="lblBalance" text="Balance: -" style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #059669;" />
            </VBox>
            
            <!-- Transactions Input -->
            <VBox spacing="12.0" style="-fx-background-color: white; -fx-padding: 15px; -fx-background-radius: 6px; -fx-border-color: #e5e7eb; -fx-border-radius: 6px;" VBox.vgrow="ALWAYS">
                <Label text="Transaction Amount (₱):" styleClass="form-label" />
                <TextField fx:id="tfAmount" promptText="Enter amount" />
                
                <VBox spacing="10.0" alignment="CENTER" style="-fx-padding: 10px 0 0 0;">
                    <Button text="Deposit" minWidth="200.0" styleClass="btn-secondary" onAction="#onDeposit" />
                    <Button text="Withdraw" minWidth="200.0" styleClass="btn-danger" onAction="#onWithdraw" />
                    <Button text="Balance Inquiry" minWidth="200.0" styleClass="btn-primary" onAction="#onBalanceInquiry" />
                </VBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
