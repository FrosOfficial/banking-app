<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="customerPane"
            prefWidth="520.0"
            prefHeight="760.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gabriel.account.utilControllers.CustomerController">

    <padding>
        <Insets top="20" right="25" bottom="25" left="25"/>
    </padding>

    <!-- ===================== HEADER ===================== -->

    <top>

        <VBox alignment="CENTER"
              spacing="8"
              BorderPane.alignment="CENTER">

            <padding>
                <Insets bottom="22"/>
            </padding>

            <Label text="Customer Banking"
                   styleClass="header-title"/>

            <Label text="Manage your account securely"
                   style="-fx-font-size:13px;
                          -fx-text-fill:#6E6E73;"/>

            <Button text="Log Out"
                    prefWidth="140"
                    prefHeight="40"
                    styleClass="btn-close"
                    onAction="#onLogOut"/>

        </VBox>

    </top>

    <!-- ===================== CONTENT ===================== -->

    <center>

        <VBox spacing="20">

            <!-- ================= SEARCH CARD ================= -->

            <VBox spacing="12"
                  styleClass="card"
                  fx:id="vboxSearch">

                <Label text="Load Account"
                       styleClass="form-label"/>

                <HBox spacing="12"
                      alignment="CENTER_LEFT">

                    <TextField fx:id="tfSearchId"
                               promptText="Enter Account ID"
                               prefHeight="42"
                               HBox.hgrow="ALWAYS"/>

                    <Button text="Load"
                            prefWidth="100"
                            prefHeight="42"
                            styleClass="btn-primary"
                            onAction="#onLoadAccount"/>

                </HBox>

                <Label fx:id="lblStatus"
                       text="Enter an Account ID to begin."
                       style="-fx-font-size:12px;
                              -fx-text-fill:#6E6E73;"/>

            </VBox>

            <!-- ================= ACCOUNT SUMMARY ================= -->

            <VBox spacing="14"
                  styleClass="card">

                <Label text="Account Summary"
                       styleClass="form-label"/>

                <Separator/>

                <HBox alignment="CENTER_LEFT">

                    <Label text="Owner"
                           styleClass="form-label"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Label fx:id="lblOwner"
                           text="-"
                           style="-fx-font-size:14px;"/>

                </HBox>

                <HBox alignment="CENTER_LEFT">

                    <Label text="Account Type"
                           styleClass="form-label"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Label fx:id="lblType"
                           text="-"
                           style="-fx-font-size:14px;"/>

                </HBox>

                <Separator/>

                <VBox spacing="6"
                      alignment="CENTER">

                    <Label text="Available Balance"
                           style="-fx-text-fill:#6E6E73;
                                  -fx-font-size:12px;"/>

                    <Label fx:id="lblBalance"
                           text="₱0.00"
                           style="-fx-font-size:30px;
                                  -fx-font-weight:bold;
                                  -fx-text-fill:#007AFF;"/>

                </VBox>

            </VBox>

            <!-- ================= TRANSACTIONS ================= -->

            <VBox spacing="18"
                  styleClass="card"
                  VBox.vgrow="ALWAYS">

                <Label text="Transaction"
                       styleClass="form-label"/>

                <TextField fx:id="tfAmount"
                           prefHeight="45"
                           promptText="Enter amount (₱)"/>

                <VBox spacing="12"
                      alignment="CENTER">

                    <Button text="Deposit"
                            prefWidth="260"
                            prefHeight="45"
                            styleClass="btn-secondary"
                            onAction="#onDeposit"/>

                    <Button text="Withdraw"
                            prefWidth="260"
                            prefHeight="45"
                            styleClass="btn-danger"
                            onAction="#onWithdraw"/>

                    <Button text="Transaction History"
                            prefWidth="260"
                            prefHeight="45"
                            styleClass="btn-primary"
                            onAction="#onTransactionHistory"/>

                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

            </VBox>

        </VBox>

    </center>

</BorderPane>