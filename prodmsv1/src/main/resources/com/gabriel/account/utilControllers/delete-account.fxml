<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefWidth="520.0"
            prefHeight="650.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gabriel.account.utilControllers.DeleteAccountController">

   <!-- ================= HEADER ================= -->

   <top>

      <VBox alignment="CENTER"
            spacing="8">

         <padding>
            <Insets top="25"
                    right="25"
                    bottom="20"
                    left="25"/>
         </padding>

         <Label text="Delete Account"
                styleClass="header-title"/>

         <Label text="Review the account information before deletion"
                style="-fx-font-size:13px;
                          -fx-text-fill:#6E6E73;"/>

      </VBox>

   </top>

   <!-- ================= CONTENT ================= -->

   <center>

      <VBox spacing="22">

         <padding>
            <Insets top="10"
                    right="25"
                    bottom="25"
                    left="25"/>
         </padding>

         <!-- Account Information Card -->

         <VBox spacing="20"
               styleClass="card">

            <Label text="Account Information"
                   styleClass="form-label"/>

            <GridPane hgap="18"
                      vgap="18">

               <columnConstraints>

                  <ColumnConstraints prefWidth="135"/>

                  <ColumnConstraints hgrow="ALWAYS"/>

               </columnConstraints>

               <!-- Account ID -->

               <Label text="Account ID"
                      styleClass="form-label"
                      GridPane.rowIndex="0"/>

               <TextField fx:id="tfId"
                          editable="false"
                          prefHeight="42"
                          GridPane.columnIndex="1"
                          GridPane.rowIndex="0"/>

               <!-- Name -->

               <Label text="Customer Name"
                      styleClass="form-label"
                      GridPane.rowIndex="1"/>

               <TextField fx:id="tfName"
                          editable="false"
                          prefHeight="42"
                          GridPane.columnIndex="1"
                          GridPane.rowIndex="1"/>

               <!-- Description -->

               <Label text="Description"
                      styleClass="form-label"
                      GridPane.rowIndex="2"/>

               <TextField fx:id="tfDesc"
                          editable="false"
                          prefHeight="42"
                          GridPane.columnIndex="1"
                          GridPane.rowIndex="2"/>

               <!-- Type -->

               <Label text="Account Type"
                      styleClass="form-label"
                      GridPane.rowIndex="3"/>

               <TextField fx:id="tfUom"
                          editable="false"
                          prefHeight="42"
                          GridPane.columnIndex="1"
                          GridPane.rowIndex="3"/>

               <!-- Balance -->

               <Label text="Current Balance"
                      styleClass="form-label"
                      GridPane.rowIndex="4"/>

               <TextField fx:id="tfBalance"
                          editable="false"
                          prefHeight="42"
                          GridPane.columnIndex="1"
                          GridPane.rowIndex="4"/>

            </GridPane>

         </VBox>

         <!-- Warning Card -->

         <VBox spacing="10"
               alignment="CENTER"
               styleClass="card">

            <Label text="⚠ Warning"
                   style="-fx-font-size:18px;
                              -fx-font-weight:bold;
                              -fx-text-fill:#FF3B30;"/>

            <Label text="This action permanently deletes the selected account."
                   wrapText="true"
                   style="-fx-font-size:13px;
                              -fx-text-fill:#6E6E73;
                              -fx-alignment:center;"/>

            <Label text="This action cannot be undone."
                   style="-fx-font-size:14px;
                              -fx-font-weight:bold;
                              -fx-text-fill:#FF3B30;"/>

         </VBox>

         <!-- Buttons -->

         <HBox alignment="CENTER"
               spacing="20">

            <Button text="Delete Account"
                    prefWidth="180"
                    prefHeight="45"
                    styleClass="btn-danger"
                    mnemonicParsing="false"
                    onAction="#onSubmit"/>

            <Button text="Cancel"
                    prefWidth="140"
                    prefHeight="45"
                    styleClass="btn-close"
                    mnemonicParsing="false"
                    onAction="#onBack"/>

         </HBox>

      </VBox>

   </center>

</BorderPane>