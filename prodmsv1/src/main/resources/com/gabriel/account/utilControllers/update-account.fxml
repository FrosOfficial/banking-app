<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefWidth="960.0"
            prefHeight="540.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gabriel.account.utilControllers.UpdateAccountController">

   <top>
      <VBox alignment="CENTER" spacing="8">
         <padding>
            <Insets top="24" right="24" bottom="16" left="24"/>
         </padding>

         <Label text="Update Account" styleClass="header-title"/>
         <Label text="Modify customer account information" style="-fx-font-size:13px; -fx-text-fill:#6E6E73;"/>
      </VBox>
   </top>

   <center>
      <VBox spacing="20">
         <padding>
            <Insets top="8" right="24" bottom="24" left="24"/>
         </padding>

         <VBox spacing="18" styleClass="card">
            <Label text="Account Information" styleClass="form-label"/>

            <GridPane hgap="18" vgap="16">
               <columnConstraints>
                  <ColumnConstraints prefWidth="140"/>
                  <ColumnConstraints hgrow="ALWAYS"/>
               </columnConstraints>

               <Label text="Account ID" styleClass="form-label" GridPane.rowIndex="0"/>
               <TextField fx:id="tfId" editable="false" prefHeight="42" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

               <Label text="Customer Name" styleClass="form-label" GridPane.rowIndex="1"/>
               <TextField fx:id="tfName" prefHeight="42" promptText="Customer name" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

               <Label text="Description" styleClass="form-label" GridPane.rowIndex="2"/>
               <TextField fx:id="tfDesc" prefHeight="42" promptText="Savings, Checking, etc." GridPane.columnIndex="1" GridPane.rowIndex="2"/>

               <Label text="Account Type" styleClass="form-label" GridPane.rowIndex="3"/>
               <ComboBox fx:id="cbUom" prefHeight="42" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

               <Label text="Balance" styleClass="form-label" GridPane.rowIndex="4"/>
               <TextField fx:id="tfBalance" prefHeight="42" promptText="0.00" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

               <Label text="Email Address" styleClass="form-label" GridPane.rowIndex="5"/>
               <TextField fx:id="tfEmail" prefHeight="42" promptText="name@example.com" GridPane.columnIndex="1" GridPane.rowIndex="5"/>

               <Label text="Password" styleClass="form-label" GridPane.rowIndex="6"/>
               <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="6">
                  <StackPane>
                     <PasswordField fx:id="tfPassword" prefHeight="42" promptText="Enter new password"/>
                     <TextField fx:id="tfPasswordPlain" prefHeight="42" promptText="Enter new password" visible="false" managed="false"/>
                  </StackPane>
                  <CheckBox fx:id="chkShowPassword" text="Show Password" onAction="#onToggleShowPassword" style="-fx-font-size:12px; -fx-text-fill:#6E6E73;"/>
               </VBox>
            </GridPane>
         </VBox>

         <HBox alignment="CENTER" spacing="20">
            <Button text="Save Changes" prefWidth="180" prefHeight="45" styleClass="btn-primary" mnemonicParsing="false" onAction="#onSubmit"/>
            <Button text="Back" prefWidth="140" prefHeight="45" styleClass="btn-close" mnemonicParsing="false" onAction="#onBack"/>
         </HBox>
      </VBox>
   </center>
</BorderPane>