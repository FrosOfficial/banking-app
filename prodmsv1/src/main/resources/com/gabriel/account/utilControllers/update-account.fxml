<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="600.0" prefWidth="300.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gabriel.account.utilControllers.UpdateAccountController">
   <top>
      <VBox alignment="CENTER" spacing="10.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
         </padding>
         <Label styleClass="header-title" text="Update Account" />
      </VBox>
   </top>
   <center>
      <VBox spacing="15.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" />
         </padding>
         <GridPane hgap="10.0" vgap="10.0">
            <columnConstraints>
               <ColumnConstraints hgrow="NEVER" minWidth="90.0" prefWidth="100.0" />
               <ColumnConstraints hgrow="ALWAYS" minWidth="150.0" prefWidth="170.0" />
            </columnConstraints>
            
            <Label text="Account ID:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="tfId" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="0" />
            
            <Label text="Name:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <TextField fx:id="tfName" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            
            <Label text="Description:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <TextField fx:id="tfDesc" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            
            <Label text="Account Type:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="3" />
            <ComboBox fx:id="cbUom" prefWidth="150.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />

            <Label text="Balance:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="4" />
            <TextField fx:id="tfBalance" GridPane.columnIndex="1" GridPane.rowIndex="4" />

            <Label text="Email:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="5" />
            <TextField fx:id="tfEmail" GridPane.columnIndex="1" GridPane.rowIndex="5" />

            <Label text="Password:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="6" />
            <PasswordField fx:id="tfPassword" GridPane.columnIndex="1" GridPane.rowIndex="6" />
         </GridPane>
         
         <HBox alignment="CENTER" spacing="20.0" style="-fx-padding: 10px 0 0 0;">
            <Button mnemonicParsing="false" onAction="#onSubmit" styleClass="btn-primary" text="Submit" />
            <Button mnemonicParsing="false" onAction="#onBack" styleClass="btn-close" text="Back" />
         </HBox>
      </VBox>
   </center>
</BorderPane>
