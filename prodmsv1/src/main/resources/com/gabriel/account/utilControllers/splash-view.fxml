<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0" prefWidth="300.0" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gabriel.account.utilControllers.SplashController">
    <VBox prefHeight="50.0" prefWidth="300.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <StackPane prefHeight="150.0" prefWidth="200.0">
            <ImageView fx:id="productImage" fitHeight="194.0" fitWidth="285.0" pickOnBounds="true" preserveRatio="true" />
        </StackPane>
        <TextArea prefHeight="200.0" prefWidth="200.0" promptText="\@Copyright" text="This is a Banking Application developed by modifying the Product Management Application template." wrapText="true">
            <padding>
                <Insets bottom="10.0" />
            </padding>
        </TextArea>
        <VBox prefHeight="200.0" prefWidth="100.0">
            <Button fx:id="btnProceed" mnemonicParsing="false" onAction="#onProceed" text="Proceed" />
        </VBox>
    </VBox>
</AnchorPane>
